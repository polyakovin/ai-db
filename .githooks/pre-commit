#!/usr/bin/env bash
# Pre-commit hook для ai-db: валидация vault перед коммитом
set -euo pipefail

echo "🔍 Pre-commit checks (ai-db)..."

# 1. Валидация vault
if [ -f meta/scripts/validate-vault.sh ]; then
  bash meta/scripts/validate-vault.sh || {
    echo "❌ Vault validation failed — fix links before committing"
    echo "ℹ️  Tip: update broken links or add missing target files"
    exit 1
  }
fi

echo "✅ All checks passed"
